<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <bpmn:process id="PublicBillpostingProcess" name="Public Billposting Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start Process">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_GetUserData" name="Get User Data">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">
              <camunda:script scriptFormat="javascript">"http://localhost:9080/user/" + username;</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="method">GET</camunda:inputParameter>
            <camunda:outputParameter name="user">
              <camunda:script scriptFormat="javascript">S(response);</camunda:script>
            </camunda:outputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ZoneSelection" name="Zone Selection" camunda:delegateExpression="${zoneSelectionDelegate}">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CheckAvailability" name="Check Availability">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://localhost:8888/postingservice</camunda:inputParameter>
            <camunda:inputParameter name="payload">
              <camunda:script scriptFormat="freemarker" resource="templates/checkAvailabilityRequest.ftl" />
            </camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">text/xml;charset=UTF-8</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
            <camunda:outputParameter name="requestId">
              <camunda:script scriptFormat="javascript">S(response).xPath("//*[local-name()='requestId']").element().textContent();</camunda:script>
            </camunda:outputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>soap-http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="Event_WaitForDecision" name="Wait for Decision">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_Decision" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="Gateway_Decision" name="Decision?">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_Confirm</bpmn:outgoing>
      <bpmn:outgoing>Flow_Cancel</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_ConfirmRequest" name="Confirm Request">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://localhost:8888/postingservice</camunda:inputParameter>
            <camunda:inputParameter name="payload">
              <camunda:script scriptFormat="freemarker" resource="templates/confirmRequest.ftl" />
            </camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">text/xml;charset=UTF-8</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
            <camunda:outputParameter name="accountHolder">
              <camunda:script scriptFormat="javascript">S(response).xPath("//*[local-name()='accountHolder']").element().textContent();</camunda:script>
            </camunda:outputParameter>
            <camunda:outputParameter name="invoiceNumber">
              <camunda:script scriptFormat="javascript">S(response).xPath("//*[local-name()='invoiceNumber']").element().textContent();</camunda:script>
            </camunda:outputParameter>
            <camunda:outputParameter name="amountDue">
              <camunda:script scriptFormat="javascript">S(response).xPath("//*[local-name()='amountDue']").element().textContent();</camunda:script>
            </camunda:outputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>soap-http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Confirm</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_WriteToFile" name="Write Order to File" camunda:delegateExpression="${writeOrderToFileDelegate}">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Confirmed" name="Confirmed">
      <bpmn:incoming>Flow_7</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_CancelRequest" name="Cancel Request">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://localhost:8888/postingservice</camunda:inputParameter>
            <camunda:inputParameter name="payload">
              <camunda:script scriptFormat="freemarker" resource="templates/cancelRequest.ftl" />
            </camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">text/xml;charset=UTF-8</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>soap-http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Cancel</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Task_PrintCancel" name="Print Cancellation" scriptFormat="javascript">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:script>print("ORDER CANCELLED");
print("Request ID: " + execution.getVariable("requestId"));</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:endEvent id="EndEvent_Cancelled" name="Cancelled">
      <bpmn:incoming>Flow_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_GetUserData" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_GetUserData" targetRef="Task_ZoneSelection" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_ZoneSelection" targetRef="Task_CheckAvailability" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_CheckAvailability" targetRef="Event_WaitForDecision" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Event_WaitForDecision" targetRef="Gateway_Decision" />
    <bpmn:sequenceFlow id="Flow_Confirm" name="Confirm" sourceRef="Gateway_Decision" targetRef="Task_ConfirmRequest">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${decision == 'confirm'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Cancel" name="Cancel" sourceRef="Gateway_Decision" targetRef="Task_CancelRequest">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${decision == 'cancel'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_ConfirmRequest" targetRef="Task_WriteToFile" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_WriteToFile" targetRef="EndEvent_Confirmed" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_CancelRequest" targetRef="Task_PrintCancel" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_PrintCancel" targetRef="EndEvent_Cancelled" />
  </bpmn:process>
  <bpmn:message id="Message_Decision" name="decisionMessage" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="PublicBillpostingProcess">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="150" y="100" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="134" y="143" width="67" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GetUserData_di" bpmnElement="Task_GetUserData">
        <dc:Bounds x="250" y="75" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ZoneSelection_di" bpmnElement="Task_ZoneSelection">
        <dc:Bounds x="400" y="75" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckAvailability_di" bpmnElement="Task_CheckAvailability">
        <dc:Bounds x="550" y="75" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_WaitForDecision_di" bpmnElement="Event_WaitForDecision">
        <dc:Bounds x="722" y="98" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="698" y="143" width="83" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Decision_di" bpmnElement="Gateway_Decision" isMarkerVisible="true">
        <dc:Bounds x="800" y="89" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="800" y="65" width="49" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ConfirmRequest_di" bpmnElement="Task_ConfirmRequest">
        <dc:Bounds x="950" y="74" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_WriteToFile_di" bpmnElement="Task_WriteToFile">
        <dc:Bounds x="1100" y="74" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Confirmed_di" bpmnElement="EndEvent_Confirmed">
        <dc:Bounds x="1262" y="97" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1254" y="143" width="51" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CancelRequest_di" bpmnElement="Task_CancelRequest">
        <dc:Bounds x="950" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PrintCancel_di" bpmnElement="Task_PrintCancel">
        <dc:Bounds x="1100" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Cancelled_di" bpmnElement="EndEvent_Cancelled">
        <dc:Bounds x="1262" y="223" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1255" y="267" width="49" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="186" y="117" />
        <di:waypoint x="250" y="117" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="350" y="115" />
        <di:waypoint x="400" y="115" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="500" y="115" />
        <di:waypoint x="550" y="115" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="650" y="115" />
        <di:waypoint x="722" y="115" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="758" y="115" />
        <di:waypoint x="801" y="115" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Confirm_di" bpmnElement="Flow_Confirm">
        <di:waypoint x="850" y="114" />
        <di:waypoint x="950" y="114" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="890" y="89" width="39" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Cancel_di" bpmnElement="Flow_Cancel">
        <di:waypoint x="825" y="139" />
        <di:waypoint x="825" y="240" />
        <di:waypoint x="950" y="240" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="892" y="213" width="35" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="1050" y="114" />
        <di:waypoint x="1100" y="114" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="1200" y="114" />
        <di:waypoint x="1262" y="114" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1050" y="240" />
        <di:waypoint x="1100" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1200" y="240" />
        <di:waypoint x="1262" y="240" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
